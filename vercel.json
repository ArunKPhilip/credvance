{
  "version": 2,
  "outputDirectory": "dist/frontend",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/[...path]?path=$1" },
    { "source": "/api", "destination": "/api/[...path]?path=" },
    { "source": "/health", "destination": "/api/[...path]?path=health" },
    { "source": "/metrics", "destination": "/api/[...path]?path=metrics" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}


