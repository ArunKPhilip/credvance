{
  "name": "credvance-enterprise-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run dev:web",
    "dev:full": "npm run dev:web",
    "dev:web": "vite",
    "dev:api": "tsx watch src/backend/server.ts",
    "build": "npm run build:web && npm run build:api",
    "ci": "npm run typecheck && npm run test && npm run build",
    "release:check": "npm run ci && npm run security:scan",
    "build:web": "vite build",
    "build:api": "tsc -p tsconfig.server.json",
    "start": "node dist/backend/server.js",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p tsconfig.web.json",
    "security:scan": "npm audit --omit=dev --audit-level=high",
    "firebase:login": "firebase login --no-localhost",
    "firebase:login:reauth": "firebase login --reauth --no-localhost",
    "firebase:whoami": "firebase login:list",
    "firebase:use": "firebase use credvance",
    "firebase:deploy": "firebase deploy --project credvance",
    "firebase:deploy:firestore": "firebase deploy --only firestore --project credvance",
    "firebase:deploy:storage": "firebase deploy --only storage --project credvance",
    "firebase:deploy:hosting": "firebase deploy --only hosting --project credvance"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.5.0",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.0.0",
    "helmet": "^8.0.0",
    "multer": "^2.1.1",
    "pino": "^9.4.0",
    "prom-client": "^15.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.9",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/supertest": "^6.0.2",
    "@vercel/node": "^5.8.17",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^2.1.3",
    "concurrently": "^9.0.1",
    "firebase-tools": "^15.13.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.8",
    "vitest": "^2.1.3"
  }
}
